    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^6.4.2",
    "wait-on": "^8.0.1"
  }
}
