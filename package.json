{
  "name": "zhuaernaosai",
  "version": "1.0.0",
  "description": "抓耳挠腮剧本制作 — 从剧本到电影流线化产出",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
